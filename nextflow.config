plugins {
    id 'nf-amazon'
}

aws {
    client {
        maxConnections = 20
        connectionTimeout = 1000000
    }
}

params {
    input                  = "samplesheet.csv"
    samplesheet_diffbind = "samplesheet_diffbind.csv" 
    protocol               = "chip"              
    outdir                 = "results"
    publish_dir_mode       = 'copy'
    fragment_size          = 200    
    single_end             = false  
    genome                 = null 
    igenomes_base          = 's3://ngi-igenomes/igenomes'
    
    skip_diffbind          = false
    skip_homer             = false
    skip_profileplyr       = false
    
    lanceotron_threshold = 0.5

    bowtie2_index          = null 
    reference_file         = null
    gtf_file               = null
    blacklist              = null 
    macs_gsize             = null 
    chrom_sizes            = null
    genomes                = [:]
}

process.shell = ['/bin/bash', '-euo', 'pipefail']

includeConfig 'conf/igenomes.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        docker.pullPolicy      = 'if-not-present'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.registry    = 'quay.io'
    }
}

executor {
    queueSize = 30
}

process {
    cpus   = 2
    memory = '4 GB'

    withName: BOWTIE2_BUILD {
        cpus   = 8
        memory = '32 GB'
        publishDir = [ path: "${params.outdir}/00_genome_index", mode: params.publish_dir_mode ]
    }

    withName: FASTQC {
        publishDir = [ path: "${params.outdir}/01_fastqc", mode: params.publish_dir_mode ]
    }

    withName: TRIMGALORE {
        cpus   = 4
        memory = '8 GB'
        publishDir = [ path: "${params.outdir}/02_trimmed", mode: params.publish_dir_mode ]
    }

    withName: BOWTIE2 {
        cpus   = 12
        memory = '32 GB'
        publishDir = [ path: "${params.outdir}/03_aligned/raw_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_SORT {
        cpus   = 6
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/03_aligned/sorted_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_INDEX {
        publishDir = [ path: "${params.outdir}/03_aligned/indexed_sorted_bam", mode: params.publish_dir_mode, enabled: false ]
    }

    withName: SAMTOOLS_STATS {
        publishDir = [ path: "${params.outdir}/03_aligned/stats", mode: params.publish_dir_mode ]
    }

    withName: PICARD_MARKDUPLICATES {
        cpus   = 4
        memory = '24 GB'
        ext.args   = '--REMOVE_DUPLICATES true --ASSUME_SORTED true --VALIDATION_STRINGENCY LENIENT --CREATE_INDEX true'
        publishDir = [ path: "${params.outdir}/04_duplicates_removed", mode: params.publish_dir_mode ]
    }

    withName: FILTERING {
        cpus   = 4
        memory = '12 GB'
    }

    withName: SAMTOOLS_INDEX_FINAL {
        publishDir = [ path: "${params.outdir}/05_final_filtered_bam", mode: params.publish_dir_mode ]
    }

    withName: DEEPTOOLS {
        cpus   = 8
        memory = '20 GB'
        publishDir = [
            [ path: "${params.outdir}/06_bigwig", mode: params.publish_dir_mode, pattern: "*.bw" ],
            [ path: "${params.outdir}/06_bigwig/qc_fingerprint", mode: params.publish_dir_mode, pattern: "*.{pdf,txt}" ]
        ]
    }

    withName: LANCEOTRON {
        cpus   = 12
        memory = '64 GB'
        time   = '20h'
        publishDir = [
            [ path: "${params.outdir}/07_lanceotron/unfiltered", mode: params.publish_dir_mode, pattern: "*.{bed,txt}" ],
            [ path: "${params.outdir}/07_lanceotron/bigwig_res1", mode: params.publish_dir_mode, pattern: "*.bw" ]
        ]
    }

    withName: FILTER_LANCEOTRON {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ 
            path: "${params.outdir}/07_lanceotron/filtered", 
            mode: params.publish_dir_mode,
            pattern: "*.filtered_full.bed" 
        ]
    }

    withName: OMNIPEAK {
        cpus   = 8
        memory = '32 GB'
        time   = '10h'
        publishDir = [ path: "${params.outdir}/08_peaks_omnipeak", mode: params.publish_dir_mode ]
    }

    withName: 'MACS3_.*' {
        cpus   = 4
        memory = '16 GB'
    }

    withName: 'MACS3_.*_NARROW' {
        publishDir = [ path: "${params.outdir}/08_peaks_macs3/narrow", mode: params.publish_dir_mode ]
    }

    withName: 'MACS3_.*_BROAD' {
        publishDir = [ path: "${params.outdir}/08_peaks_macs3/broad", mode: params.publish_dir_mode ]
    }

    withName: CALC_FRIP {
        cpus   = 4
        memory = '16 GB'
        publishDir = [ path: "${params.outdir}/08_peaks_macs3/frip_stats", mode: params.publish_dir_mode ]
    }

    withName: HOMER_MACS {
        cpus   = 6
        memory = '24 GB'
        publishDir = [ path: "${params.outdir}/09_annotation/macs", mode: params.publish_dir_mode ]
    }

    withName: HOMER_LANCE {
        cpus   = 6
        memory = '24 GB'
        publishDir = [ path: "${params.outdir}/09_annotation/lanceotron", mode: params.publish_dir_mode ]
    }

    withName: HOMER_OMNI {
        cpus   = 6
        memory = '24 GB'
        publishDir = [ path: "${params.outdir}/09_annotation/omnipeak", mode: params.publish_dir_mode ]
    }

    withName: DIFFBIND_MACS {
        cpus   = 12
        memory = '48 GB'
        time   = '12h'
        publishDir = [ path: "${params.outdir}/10_diffbind/macs", mode: params.publish_dir_mode ]
    }

    withName: DIFFBIND_LANCE {
        cpus   = 12
        memory = '48 GB'
        time   = '12h'
        publishDir = [ path: "${params.outdir}/10_diffbind/lanceotron", mode: params.publish_dir_mode ]
    }

    withName: DIFFBIND_OMNI {
        cpus   = 12
        memory = '48 GB'
        time   = '12h'
        publishDir = [ path: "${params.outdir}/10_diffbind/omnipeak", mode: params.publish_dir_mode ]
    }

    withName: PROFILEPLYR_MACS {
        cpus   = 8
        memory = '32 GB'
        time   = '4h'
        publishDir = [ path: "${params.outdir}/11_profileplyr/macs", mode: params.publish_dir_mode ]
    }

    withName: PROFILEPLYR_LANCE {
        cpus   = 8
        memory = '32 GB'
        time   = '4h'
        publishDir = [ path: "${params.outdir}/11_profileplyr/lanceotron", mode: params.publish_dir_mode ]
    }

    withName: PROFILEPLYR_OMNI {
        cpus   = 8
        memory = '32 GB'
        time   = '4h'
        publishDir = [ path: "${params.outdir}/11_profileplyr/omnipeak", mode: params.publish_dir_mode ]
    }

    withName: MULTIQC {
        cpus   = 2
        memory = '4 GB'
        publishDir = [ path: "${params.outdir}/12_MultiQC_Report", mode: params.publish_dir_mode ]
    }
}
